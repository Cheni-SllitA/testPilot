{
  "manifest_version": 3,
  "name": "TestPilot",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "tabs",
    "windows",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}